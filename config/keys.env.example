# ============================================================
# ARIS — Configuration
# Copy this file to keys.env and fill in your values.
# ============================================================

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which LLM to use for all AI features.
# Options: anthropic | openai | ollama | gemini
# Default: anthropic
LLM_PROVIDER=anthropic

# Model name — leave blank to use the provider default:
#   anthropic  →  claude-sonnet-4-20250514
#   openai     →  gpt-4o
#   ollama     →  llama3.1
#   gemini     →  gemini-1.5-pro
LLM_MODEL=

# Base URL for OpenAI-compatible endpoints.
# Leave blank for official provider endpoints.
#
# Examples:
#   Groq:         LLM_BASE_URL=https://api.groq.com/openai/v1
#                 LLM_MODEL=llama-3.1-70b-versatile
#
#   Together AI:  LLM_BASE_URL=https://api.together.xyz/v1
#                 LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
#   Mistral:      LLM_BASE_URL=https://api.mistral.ai/v1
#                 LLM_MODEL=mistral-large-latest
#
#   LM Studio:    LLM_BASE_URL=http://localhost:1234/v1
#                 LLM_MODEL=loaded-model-name
#
#   Ollama:       LLM_PROVIDER=ollama  (no URL needed; uses localhost:11434)
#                 LLM_MODEL=llama3.1
LLM_BASE_URL=

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Fill in only the key matching your LLM_PROVIDER above.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (or Groq / Together AI / Mistral — they use the same variable)
# OpenAI:     https://platform.openai.com/api-keys
# Groq:       https://console.groq.com/keys
# Together:   https://api.together.xyz/settings/api-keys
# Mistral:    https://console.mistral.ai/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ollama requires no API key (runs locally).
# Install: https://ollama.com  then: ollama pull llama3.1

# ── Data Source API Keys ───────────────────────────────────────────────────────
# All free; each takes under 5 minutes to register.

# Regulations.gov — federal rulemaking dockets
# https://open.gsa.gov/api/regulationsgov/
REGULATIONS_GOV_KEY=

# Congress.gov — congressional bills and hearing schedules
# https://api.congress.gov/sign-up/
CONGRESS_GOV_KEY=

# LegiScan — US state legislation (30,000 calls/month free)
# https://legiscan.com/legiscan
LEGISCAN_KEY=

# ── Optional Settings ─────────────────────────────────────────────────────────

# How many days back to look for new documents on each fetch (default: 30)
LOOKBACK_DAYS=30

# ── Domain configuration ──────────────────────────────────────────────────────
# Which regulatory domains to monitor.
# Options: ai | privacy | both  (default: both)
ACTIVE_DOMAINS=both


# Minimum Claude relevance score to store a summary (0.0–1.0, default: 0.5)
MIN_RELEVANCE_SCORE=0.5

# SQLite database path (default: ./output/aris.db)
DB_PATH=./output/aris.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Notifications ─────────────────────────────────────────────────────────────
# Email — uses SMTP (works with Gmail app passwords, SendGrid, etc.)
# NOTIFY_EMAIL=recipient@yourcompany.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=sender@gmail.com
# SMTP_PASSWORD=your-app-password

# Slack — create an incoming webhook at https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Notification triggers (true/false, all default true when a channel is configured)
# NOTIFY_ON_CRITICAL=true     # always notify when critical-urgency docs detected
# NOTIFY_ON_HIGH=true         # notify on high-urgency docs
# NOTIFY_ON_DIGEST=true       # send digest after every scheduled run
# NOTIFY_DEADLINE_DAYS=14     # alert when a horizon deadline is within N days
