# ============================================================
# ARIS — API Keys Configuration
# Copy this file to keys.env and fill in your keys.
# All keys below are available for FREE from the listed URLs.
# ============================================================

# Anthropic (required for AI summarization)
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Regulations.gov (required for Federal rulemaking dockets)
# Get at: https://open.gsa.gov/api/regulationsgov/
# Free; instant registration
REGULATIONS_GOV_KEY=your_regs_gov_key_here

# Congress.gov (required for Congressional bill text)
# Get at: https://api.congress.gov/sign-up/
# Free; instant registration
CONGRESS_GOV_KEY=your_congress_gov_key_here

# LegiScan (required for state legislation)
# Get at: https://legiscan.com/legiscan (free account)
# Free tier: 30,000 API calls/month
LEGISCAN_KEY=your_legiscan_key_here

# ============================================================
# OPTIONAL SETTINGS
# ============================================================

# How many days back to look for new documents (default: 30)
LOOKBACK_DAYS=30

# Minimum relevance score to include a document (0.0–1.0)
MIN_RELEVANCE_SCORE=0.5

# SQLite database path (default: ./output/aris.db)
DB_PATH=./output/aris.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
